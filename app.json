{
  "expo": {
    "name": "Filmeio",
    "slug": "filmeio",
    "scheme": "filmeio",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.filmieo.app"
    },
    "android": {
      "package": "com.filmeio.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F7F7F2"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "eb234b38-d79a-4935-81f1-a39fbd26a91b"
      }
    },
    "owner": "ib.yebdri"
  }
}