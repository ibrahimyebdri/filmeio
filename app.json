{
  "expo": {
    "name": "Filmeio",
    "slug": "filmeio",
    "scheme": "filmeio",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.filmieo.app"
    },
    "android": {
      "package": "com.filmeio.app",
      "adaptiveIcon": {
        "backgroundColor": "#F7F7F2"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
